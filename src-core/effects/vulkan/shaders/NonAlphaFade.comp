#version 450
// Port of NonAlphaFade in LayerBlendingFunctions.metal.

layout(local_size_x = 64) in;

#include "blend_common.glsl"

layout(std430, set = 0, binding = 0) buffer Result { uint result[]; };

void main() {
    uint index = gl_GlobalInvocationID.x;
    if (index >= uint(data.nodeCount)) return;
    uvec4 color = unpackPx(result[index]);
    vec3 hsv = toHSV(color);
    hsv.z *= data.fadeFactor;
    result[index] = packPx(fromHSV(hsv));
}
