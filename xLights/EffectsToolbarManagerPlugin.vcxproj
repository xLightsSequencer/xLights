    <!-- XLightsPluginManager scans <exeDir>/xlights_plugins/, not this
         project's own output dir - without this copy, a rebuilt DLL just
         sits in x64\Debug\ and xLights keeps loading whatever stale copy
         was last placed in xlights_plugins\ by hand (this bit the Voronoi
         Cells effect plugin for several days before being caught). -->
    <PostBuildEvent>
      <Command>if not exist "$(OutDir)xlights_plugins" mkdir "$(OutDir)xlights_plugins"
xcopy /Y "$(TargetPath)" "$(OutDir)xlights_plugins\"</Command>
    </PostBuildEvent>
