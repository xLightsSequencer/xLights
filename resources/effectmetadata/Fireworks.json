            "controlType": "slider",
            "default": 50,
            "min": 0,
            "max": 100,
            "lockable": true
        },
        {
            "id": "FIRETIMING",
            "label": "Fire with timing track",
            "type": "bool",
            "controlType": "checkbox",
            "default": false,
            "lockable": true
        },
        {
            "id": "FIRETIMINGTRACK",
            "label": "Timing Track",
            "type": "enum",
            "controlType": "choice",
            "options": [],
            "default": "",
            "dynamicOptions": "timingTracks"
        }
    ],
    "visibilityRules": [
        {
            "when": {
                "property": "Fireworks_UseMusic",
                "equals": true
            },
            "enable": [
                "Fireworks_Sensitivity"
            ]
        },
        {
            "when": {
                "property": "FIRETIMING",
                "equals": true
            },
            "enable": [
                "FIRETIMINGTRACK"
            ]
        },
        {
            "when": {
                "any": [
                    "FIRETIMING",
                    "Fireworks_UseMusic"
                ]
            },
            "disable": [
                "Fireworks_Explosions"
            ]
        }
    ]
}
