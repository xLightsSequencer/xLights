            "max": 10,
            "valueCurve": true,
            "lockable": true,
            "description": "Adjusts the animation speed curve. Positive values accelerate toward the end, negative values decelerate."
        },
        {
            "id": "Galaxy_Reverse",
            "label": "Reverse",
            "type": "bool",
            "controlType": "checkbox",
            "default": false,
            "description": "Reverses the direction the spiral arm rotates."
        },
        {
            "id": "Galaxy_Blend_Edges",
            "label": "Blend Edges",
            "type": "bool",
            "controlType": "checkbox",
            "default": true,
            "description": "When enabled, the spiral arm edges fade smoothly using alpha blending instead of having hard edges."
        },
        {
            "id": "Galaxy_Inward",
            "label": "Inward",
            "type": "bool",
            "controlType": "checkbox",
            "default": false,
            "description": "When enabled, the spiral draws from the outside inward. When disabled, it draws from the center outward."
        },
        {
            "id": "Galaxy_Scale",
            "label": "Scale To Buffer",
            "type": "bool",
            "controlType": "checkbox",
            "default": true,
            "description": "When enabled, radius and width values are treated as percentages of the buffer size rather than absolute pixel values."
